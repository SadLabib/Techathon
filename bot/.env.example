# Discord bot token (from the Discord Developer Portal -> your app -> Bot)
DISCORD_TOKEN=

# Backend API base URL (the shared source of truth)
BACKEND_URL=http://localhost:8000

# Google Gemini free-tier API key (https://aistudio.google.com/apikey).
# Optional — if left blank the bot replies with plain (still correct) text.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Channel ID the bot posts proactive alerts to (bonus feature; optional)
ALERT_CHANNEL_ID=
